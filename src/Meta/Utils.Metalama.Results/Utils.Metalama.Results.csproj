<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
	<TargetFrameworks>netstandard2.0;net9.0;net10.0</TargetFrameworks>
	<OutputType>Library</OutputType>

	<RootNamespace>LightningArc.Utils.Metalama</RootNamespace>
	<NoWarn>IDE0130;NU5128;CA1865</NoWarn>

	<!--<MetalamaEnabled>false</MetalamaEnabled>-->
	<!--<MetalamaCompileTimeProject>true</MetalamaCompileTimeProject>-->
	<MetalamaRemoveCompileTimeOnlyCode>false</MetalamaRemoveCompileTimeOnlyCode>
  </PropertyGroup>

  <PropertyGroup>
	<AssemblyName>LightningArc.Utils.Metalama.Results</AssemblyName>
	<PackageTags>Metalama, PostSharp, Aspect, Attribute, Results</PackageTags>
  </PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Metalama.Framework" />
		<PackageReference Include="Metalama.Framework.Sdk" PrivateAssets="all" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Utils.Metalama\Utils.Metalama.csproj" />
		<ProjectReference Include="..\..\Core\Utils.Results\Utils.Results.csproj" />
		<!--<MetalamaCompileTimeAssembly Include="..\Utils.Metalama\bin\$(Configuration)\netstandard2.0\LightningArc.Utils.Metalama.dll" />-->
	</ItemGroup>

	<!--
	<ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
		<PackageReference Include="PolySharp" PrivateAssets="All" />
		<MetalamaCompileTimePackage Include="PolySharp" />
	</ItemGroup>
	-->
</Project>
