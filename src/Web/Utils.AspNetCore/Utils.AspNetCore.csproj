<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFrameworks>net6.0;net9.0;net10.0</TargetFrameworks>
        <OutputType>Library</OutputType>

        <RootNamespace>LightningArc.Utils.AspNetCore</RootNamespace>
        <NoWarn>IDE0130;NU5128</NoWarn>
    </PropertyGroup>

    <PropertyGroup>
        <AssemblyName>LightningArc.Utils.AspNetCore</AssemblyName>
        <PackageTags>Utils</PackageTags>
        <IncludeBuildOutput>false</IncludeBuildOutput>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Results.AspNetCore\Results.AspNetCore.csproj" />
        <ProjectReference Include="..\CORS.AspNetCore\CORS.AspNetCore.csproj" />
    </ItemGroup>

    <ItemGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net9.0'))">
        <ProjectReference Include="..\OpenAPI.AspNetCore\OpenAPI.AspNetCore.csproj" />
    </ItemGroup>
</Project>







