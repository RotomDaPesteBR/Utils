<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
	<TargetFrameworks>netstandard2.0;net9.0;net10.0</TargetFrameworks>

	<RootNamespace>LightningArc.Utils.Json</RootNamespace>

	<NoWarn>$(NoWarn);IDE0130</NoWarn>
  </PropertyGroup>

  <PropertyGroup>
	<AssemblyName>LightningArc.Utils.Json</AssemblyName>
	<PackageTags>Utils</PackageTags>
  </PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\Utils.Abstractions\Utils.Abstractions.csproj" />
	</ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
	<PackageReference Include="PolySharp" PrivateAssets="All" />
	<PackageReference Include="System.Text.Json" />
  </ItemGroup>
</Project>

