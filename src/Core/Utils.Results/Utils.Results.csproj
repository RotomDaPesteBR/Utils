<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
	<TargetFrameworks>netstandard2.0;net9.0;net10.0</TargetFrameworks>

	<RootNamespace>LightningArc.Utils.Results</RootNamespace>

	<NoWarn>$(NoWarn);IDE0130</NoWarn>
  </PropertyGroup>

  <PropertyGroup>
	<AssemblyName>LightningArc.Utils.Results</AssemblyName>
	<PackageTags>Utils</PackageTags>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
	<PackageReference Include="PolySharp" PrivateAssets="All" />
	<PackageReference Include="System.Text.Json" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
	<InternalsVisibleTo Include="LightningArc.Utils.AspNet.Results" />

	<InternalsVisibleTo Include="LightningArc.Utils.Tests" />
  </ItemGroup>
</Project>


