<Project>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <CentralPackageTransitivePinningEnabled>true</CentralPackageTransitivePinningEnabled>
    <CentralPackageFloatingVersionsEnabled>true</CentralPackageFloatingVersionsEnabled>
    <CentralPackageVersionOverrideEnabled>true</CentralPackageVersionOverrideEnabled>
  </PropertyGroup>

  <PropertyGroup>
    <PackageVersion>1.5.0</PackageVersion> 
  </PropertyGroup>
  
  <!-- Microsoft -->
  <PropertyGroup>
      <MicrosoftPackagesVersion>10.0.5</MicrosoftPackagesVersion> 
  </PropertyGroup>
  <ItemGroup>
    <PackageVersion Include="Microsoft.Extensions.Configuration" Version="$(MicrosoftPackagesVersion)" />
    <PackageVersion Include="Microsoft.Extensions.Configuration.Abstractions" Version="$(MicrosoftPackagesVersion)" />
    <PackageVersion Include="Microsoft.Extensions.Configuration.Binder" Version="$(MicrosoftPackagesVersion)" />
    <PackageVersion Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="$(MicrosoftPackagesVersion)" />
    <PackageVersion Include="Microsoft.Extensions.Logging" Version="$(MicrosoftPackagesVersion)" />
    <PackageVersion Include="Microsoft.Extensions.Logging.Abstractions" Version="$(MicrosoftPackagesVersion)" />
  </ItemGroup>

  <!-- Compatibility -->
  <ItemGroup>
    <PackageVersion Include="PolySharp" Version="1.15.0" />
    <PackageVersion Include="System.Text.Json" Condition="'$(TargetFramework)' == 'net6.0'" Version="8.0.6" />
    <PackageVersion Include="System.Text.Json" Condition="'$(TargetFramework)' == 'netstandard2.0' 
                                                       OR '$(TargetFramework)' == 'net8.0' 
                                                       OR '$(TargetFramework)' == 'net9.0' 
                                                       OR '$(TargetFramework)' == 'net10.0'" 
    Version="$(MicrosoftPackagesVersion)" />
  </ItemGroup>

  <!-- Mappers -->
  <ItemGroup>
    <PackageVersion Include="AutoMapper" Version="16.1.1" />
    <PackageVersion Include="Mapster" Version="10.0.1" />
    <PackageVersion Include="Mapster.DependencyInjection" Version="10.0.0" />
  </ItemGroup>

  <!-- Drivers -->
  <ItemGroup>
    <PackageVersion Include="Microsoft.Data.SqlClient" Version="7.0.0" />
    <PackageVersion Include="Oracle.ManagedDataAccess.Core" Version="23.26.100" />
  </ItemGroup>
  
  <!-- ORMs -->
  <ItemGroup>
    <PackageVersion Include="Dapper" Version="2.1.66" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore" Condition="'$(TargetFramework)' == 'netstandard2.0'" Version="3.1.32" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore" Condition="'$(TargetFramework)' == 'net9.0'" Version="9.0.11" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore" Condition="'$(TargetFramework)' == 'net10.0'" Version="$(MicrosoftPackagesVersion)" />
  </ItemGroup>

  <!-- AspNetCore -->
  <ItemGroup>
    <PackageVersion Include="Microsoft.AspNetCore.OpenApi" Condition="'$(TargetFramework)' == 'net8.0'" Version="8.0.20" />
    <PackageVersion Include="Microsoft.AspNetCore.OpenApi" Condition="'$(TargetFramework)' == 'net9.0'" Version="9.0.10" />
    <PackageVersion Include="Microsoft.AspNetCore.OpenApi" Condition="'$(TargetFramework)' == 'net10.0'" Version="$(MicrosoftPackagesVersion)" />
  </ItemGroup>
  
  <!-- Metalama -->
  <PropertyGroup>
      <MetalamaPackagesVersion>2026.0.17</MetalamaPackagesVersion> 
  </PropertyGroup>
  <ItemGroup>
    <PackageVersion Include="Metalama.Framework" Version="$(MetalamaPackagesVersion)" />
    <PackageVersion Include="Metalama.Framework.Sdk" Version="$(MetalamaPackagesVersion)" />
    <PackageVersion Include="Metalama.Extensions.DependencyInjection" Version="$(MetalamaPackagesVersion)" />
  </ItemGroup>
  
  <!-- Data Annotations -->
  <ItemGroup>
    <PackageVersion Include="System.ComponentModel.Annotations" Version="5.0.0" />
  </ItemGroup>
  
  <!-- Utils -->
  <ItemGroup>
    <PackageVersion Include="Humanizer" Version="3.0.1" />
  </ItemGroup>
  
  <!-- Tests -->
  <ItemGroup> 
    <PackageVersion Include="TUnit" Version="1.16.4" />
    <PackageVersion Include="TUnit.AspNetCore" Version="1.16.4" />
    <PackageVersion Include="Moq" Version="4.20.72" />
    <PackageVersion Include="coverlet.collector" Version="8.0.1" />
    <PackageVersion Include="Microsoft.EntityFrameworkCore.InMemory" Version="$(MicrosoftPackagesVersion)" />
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="18.3.0" />
    <PackageVersion Include="xunit" Version="2.9.3" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="3.1.5" />
  </ItemGroup>
  
  <!-- Self -->
  <ItemGroup> 
    <PackageVersion Include="LightningArc.Utils" Version="$(PackageVersion)" />
    <PackageVersion Include="LightningArc.Utils.Metalama" Version="$(PackageVersion)" />
  </ItemGroup>
</Project>