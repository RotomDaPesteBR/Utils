<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFrameworks>net6.0;net9.0;net10.0</TargetFrameworks>
        <OutputType>Library</OutputType>

        <RootNamespace>LightningArc.Utils.AspNet</RootNamespace>
        <NoWarn>IDE0130;NU5128</NoWarn>
    </PropertyGroup>

    <PropertyGroup>
        <AssemblyName>LightningArc.Utils.AspNet</AssemblyName>
        <PackageTags>Utils</PackageTags>
        <IncludeBuildOutput>false</IncludeBuildOutput>
    </PropertyGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Utils.AspNet.Results\Utils.AspNet.Results.csproj" />
        <ProjectReference Include="..\Utils.AspNet.CORS\Utils.AspNet.CORS.csproj" />
    </ItemGroup>

    <ItemGroup Condition="$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net9.0'))">
        <ProjectReference Include="..\Utils.AspNet.OpenAPI\Utils.AspNet.OpenAPI.csproj" />
    </ItemGroup>
</Project>

